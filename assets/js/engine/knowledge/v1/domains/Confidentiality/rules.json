[
  {
    "id": "RULE_CONFIDENTIALITY_PRESENT",
    "name": "Confidentiality Present",
    "description": "Checks if Confidentiality is present.",
    "category": "Completeness",
    "severity": "Neutral",
    "status": "production",
    "when": {
      "all": [
        { "type": "conceptExists", "value": "CONCEPT_CONFIDENTIALITY" }
      ]
    },
    "then": { "type": "createFinding", "findingType": "ConfidentialityPresent" }
  },
  {
    "id": "RULE_CONFIDENTIALITY_MISSING",
    "name": "Missing Confidentiality",
    "description": "Checks if Confidentiality is unexpectedly missing.",
    "category": "Completeness",
    "severity": "High",
    "status": "production",
    "when": {
      "all": [
        { "type": "documentRequiresConcept", "value": "CONCEPT_CONFIDENTIALITY" },
        { "type": "conceptMissing", "value": "CONCEPT_CONFIDENTIALITY" }
      ]
    },
    "then": { "type": "createFinding", "findingType": "MissingConfidentiality" }
  },
  {
    "id": "RULE_CONFIDENTIALITY_MUTUALITY_RISK",
    "name": "Asymmetric Confidentiality Risk",
    "description": "Checks if confidentiality obligations are only unilateral in a Mutual NDA.",
    "category": "Risk",
    "severity": "High",
    "status": "production",
    "when": {
      "all": [
        { "type": "conceptExists", "value": "CONCEPT_CONFIDENTIALITY" },
        { "type": "documentTypeEquals", "value": "Mutual NDA" },
        { "type": "asymmetricObligation", "value": "ACTION_PROTECT" }
      ]
    },
    "then": { "type": "createFinding", "findingType": "AsymmetricConfidentiality" }
  }
]